PORT=5000

NODE_ENV=production

JWT_SECRET=replace_with_strong_secret

PYTHON_SERVICE_URL=http://127.0.0.1:8000

SUPABASE_URL=https://your-project-ref.supabase.co

SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

SUPABASE_ANON_KEY=replace_with_anon_key

FRONTEND_ORIGIN=https://your-frontend-domain.netlify.app
NETLIFY_ORIGIN=https://your-frontend-domain.netlify.app

SEARCH_TIMEOUT_MS=12000

# Optional per-IP fixed-window limits (requests per 60s)
RATE_LIMIT_SEARCH_PER_MIN=48
RATE_LIMIT_AUTH_REGISTER_PER_MIN=12
RATE_LIMIT_AUTH_LOGIN_PER_MIN=30
RATE_LIMIT_EVALUATE_PER_MIN=20
